{
  "name": "bluekeys",
  "version": "1.0.0",
  "description": "A feature-rich terminal typing test inspired by Monkeytype — with themes, vim/emacs keybindings, and detailed stats",
  "type": "module",
  "main": "dist/cli/index.js",
  "bin": {
    "bluekeys": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx src/cli/index.tsx",
    "build": "tsc -p tsconfig.json && node -e \"const fs=require('fs');fs.cpSync('src/constants/languages/data','dist/constants/languages/data',{recursive:true});fs.cpSync('src/constants/quotes/data','dist/constants/quotes/data',{recursive:true})\"",
    "start": "node dist/cli/index.js",
    "build:binary": "bun scripts/build-binary.ts",
    "test": "vitest run",
    "preversion": "pnpm test",
    "postversion": "git push && git push --tags",
    "release": "npm version",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "typing",
    "typing-test",
    "monkeytype",
    "terminal",
    "cli",
    "wpm",
    "speed-test",
    "keyboard",
    "practice",
    "ink",
    "tui",
    "vim"
  ],
  "author": "anirban12d",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/anirban12d/bluekeys.git"
  },
  "homepage": "https://github.com/anirban12d/bluekeys",
  "bugs": {
    "url": "https://github.com/anirban12d/bluekeys/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.23.0",
  "dependencies": {
    "ink": "^6.8.0",
    "react": "^19.2.4",
    "smol-toml": "^1.6.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^4.0.18"
  }
}
